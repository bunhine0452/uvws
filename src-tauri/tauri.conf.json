{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "uvws",
  "version": "0.3.0",
  "identifier": "com.pyspace.uvws",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1422",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "uvws — Local AI Orchestrator",
        "width": 1120,
        "height": 740,
        "minWidth": 900,
        "minHeight": 600,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "-"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/bunhine0452/uvws/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IENBNUQxQTAzNjQzRUExN0QKUldSOW9UNWtBeHBkeWdSdDlDKzdqRDIvQlFTS0hLZjVZcEMrcnVtN2t2RUFwZ2FlY1dEYlNWU2QK"
    }
  }
}